# ═══════════════════════════════════════════════════════════════
# FRONTEND — copia este archivo a .env en la RAÍZ del proyecto
#   copy .env.example .env
# Reinicia "npm run dev" después de cada cambio.
# ═══════════════════════════════════════════════════════════════

# URL de tu API (backend). Debe incluir /api si tus rutas van bajo /api
# Local (servidor incluido en server/):  http://localhost:3000/api
# Producción:                            https://tu-dominio.com/api
VITE_API_URL=http://localhost:3000/api

# LiveKit — WebSocket del proyecto (cloud.livekit.io)
VITE_LIVEKIT_URL=wss://your-project.livekit.cloud

# Reporte clínico — panel profesional
# Dev (evita CORS vía proxy de Vite):  /api/datos_reporte
# Directo (ngrok):                      https://neuter-acrobat-flatten.ngrok-free.dev/datos_reporte
VITE_REPORT_API_URL=/api/datos_reporte

# Si la API falla, usar datos demo (Carlos Mendoza). Pon false para solo mostrar error.
VITE_REPORT_FALLBACK_DEMO=true

# Supabase — opcional (dejar vacío si no lo usas)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
